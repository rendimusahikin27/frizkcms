<!-- Skrip Vanilla JS untuk Efek Sidebar -->
<script>
    function toggleMenu(element) {
        // Jangan buka/tutup submenu saat sidebar dalam mode mini
        const layout = document.querySelector('.frizk-layout');
        if(layout.classList.contains('collapsed')) return;

        const parentLi = element.parentElement;
        const isOpen = parentLi.classList.contains('open');

        if (isOpen) {
            parentLi.classList.remove('open');
        } else {
            parentLi.classList.add('open');
        }
    }

    function toggleSidebar() {
        const layout = document.querySelector('.frizk-layout');
        layout.classList.toggle('collapsed');
        
        // Simpan state di LocalStorage & bersihkan menu yang terbuka
        if (layout.classList.contains('collapsed')) {
            localStorage.setItem('sidebarState', 'collapsed');
            document.querySelectorAll('.fz-has-submenu.open').forEach(el => el.classList.remove('open'));
        } else {
            localStorage.setItem('sidebarState', 'expanded');
            
            // Re-open menu aktif jika diperbesar lagi
            const currentActive = document.querySelector('.fz-menu-item.active');
            if(currentActive) {
                currentActive.parentElement.classList.add('open');
            }
        }
    }

    // Pengecekan saat halaman dimuat
    document.addEventListener('DOMContentLoaded', () => {
        const layout = document.querySelector('.frizk-layout');
        const savedState = localStorage.getItem('sidebarState');
        
        if (savedState === 'collapsed') {
            layout.classList.add('collapsed');
            document.querySelectorAll('.fz-has-submenu.open').forEach(el => el.classList.remove('open'));
        }
    });
</script>