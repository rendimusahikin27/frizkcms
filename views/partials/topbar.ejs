<div class="frizk-topbar">
    <!-- Kiri: Logo & Breadcrumb -->
    <div class="topbar-brand">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
        <span>FrizkCMS</span>
        
        <% if (typeof path !== 'undefined' && path.startsWith('/admin')) { %>
            <span style="margin: 0 0.5rem; color: var(--border-color);">/</span>
            <span style="font-size: 0.875rem; color: var(--text-muted);"><%= typeof title !== 'undefined' ? title : 'Dashboard' %></span>
        <% } %>
    </div>

    <!-- Kanan: Master Actions -->
    <div class="topbar-actions">
        <a href="/" class="icon-btn" title="Visit Site">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
        </a>
        <a href="/admin/posts/new" class="btn btn-primary btn-sm" style="text-decoration: none; width: auto; color: white;">
            + New Post
        </a>
        <a href="/admin" style="text-decoration: none;">
            <div class="avatar" title="<%= user.username %>">
                <%= user.username.charAt(0).toUpperCase() %>
            </div>
        </a>
    </div>
</div>