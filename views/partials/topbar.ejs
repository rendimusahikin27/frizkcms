<div id="frizk-admin-bar">
    
    <!-- KIRI: Brand & Navigasi Cepat -->
    <div class="ab-group">
        
        <!-- 1. Logo Frizk (Hover untuk Tentang) -->
        <div class="ab-item-wrapper">
            <a href="/admin" class="ab-item" style="padding-left: 8px;">
                <span class="ab-icon">
                    <svg width="24" height="24" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="50" cy="50" r="48" fill="none" />
                        <path fill="#F2F4F3" d="
                            M 31 22 L 31 24 C 34 24, 35 25, 35 28 L 35 72 
                            C 35 75, 34 76, 31 76 L 31 78 L 52 78 L 52 76 
                            C 49 76, 48 75, 48 72 L 48 53 L 57 53 
                            C 60 53, 62 55, 63 58 L 65 58 L 64 45 L 62 45 
                            C 61 48, 59 50, 57 50 L 48 50 
                            C 40 50, 31 54, 27 65 C 28 58, 35 48, 48 48 
                            L 48 28 L 63 28 C 67 28, 69 31, 70 36 
                            L 72 36 L 70 22 Z" 
                        />
                    </svg>
                </span>
                <span style="font-family: var(--font-serif); font-size: 15px; font-weight: 700; margin-left: 2px;">Frizk</span>
            </a>
            <!-- Dropdown Terang Melayang -->
            <div class="ab-submenu">
                <a href="#">Tentang FrizkCMS</a>
                <a href="#">Dokumentasi Web</a>
                <a href="#">GitHub Repository</a>
            </div>
        </div>

        <!-- Pemisah Visual (Garis Tipis) -->
        <div style="width: 1px; height: 20px; background: rgba(255,255,255,0.2); margin: 0 8px;"></div>

        <!-- 2. Kunjungi Situs Publik -->
        <div class="ab-item-wrapper">
            <a href="/" class="ab-item" target="_blank" title="Buka situs di tab baru">
                <span class="ab-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
                </span>
                Lihat Situs
            </a>
        </div>
    </div>

    <!-- TENGAH / KANAN: Aksi & Akun -->
    <div class="ab-group">
        
        <!-- Tombol Tulis Menonjol (Ciri khas aplikasi modern) -->
        <div class="ab-item-wrapper" style="margin-right: 12px;">
            <a href="/admin/posts/new" class="ab-item action-btn">
                <span class="ab-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                </span>
                Tulis
            </a>
        </div>

        <!-- Akun Admin -->
        <div class="ab-item-wrapper">
            <a href="/admin/settings" class="ab-item">
                <div class="ab-avatar"><%= user.username.charAt(0).toUpperCase() %></div>
                <span style="margin-left: 2px;"><%= user.username %></span>
                <!-- Ikon Panah Bawah -->
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="opacity: 0.6;"><polyline points="6 9 12 15 18 9"></polyline></svg>
            </a>
            <!-- Dropdown Rata Kanan -->
            <div class="ab-submenu right-align">
                <a href="/admin/settings">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
                    Pengaturan Profil
                </a>
                <a href="/admin/logout" style="color: #DC2626 !important;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
                    Log Keluar
                </a>
            </div>
        </div>

    </div>
</div>