<%- include('../partials/header.ejs') %>
<%- include('../partials/topbar.ejs') %>
<%- include('../partials/sidebar.ejs') %>

<main class="frizk-main">
    <div class="frizk-content">
        <h1 class="page-title">Good morning, <%= user.username %>.</h1>
        
        <p style="color: var(--text-muted); font-size: 0.875rem; margin-bottom: 2rem;">
            Here is what's happening with your project today.
        </p>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1rem;">
            <div style="border: 1px solid var(--border-color); border-radius: 8px; padding: 1.5rem;">
                <h3 style="font-size: 0.875rem; color: var(--text-muted); margin-bottom: 0.5rem;">Total Posts</h3>
                <p style="font-size: 2rem; font-weight: 600;">0</p>
            </div>
            <div style="border: 1px solid var(--border-color); border-radius: 8px; padding: 1.5rem;">
                <h3 style="font-size: 0.875rem; color: var(--text-muted); margin-bottom: 0.5rem;">Database Engine</h3>
                <p style="font-size: 1.25rem; font-weight: 600; text-transform: uppercase;"><%= dbType %></p>
            </div>
        </div>
    </div>
</main>

<%- include('../partials/footer.ejs') %>