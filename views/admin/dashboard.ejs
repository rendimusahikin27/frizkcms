<%- include('../partials/header.ejs') %>
<%- include('../partials/topbar.ejs') %>
<%- include('../partials/sidebar.ejs') %>

<main class="frizk-main">
    <div class="frizk-content">
        <!-- Menggunakan Font Serif Elegan untuk Sapaan -->
        <h1 class="page-title" style="font-size: 2.25rem;">Selamat pagi, <%= user.username %>.</h1>
        
        <p style="color: var(--text-muted); font-size: 1rem; margin-bottom: 2.5rem;">
            Berikut adalah ringkasan dari situs FrizkCMS Anda hari ini.
        </p>

        <!-- Stat Cards -->
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem;">
            
            <!-- Card 1 -->
            <div style="background: var(--surface-color); border: 1px solid var(--border-color); border-radius: var(--radius); padding: 1.5rem; box-shadow: var(--shadow-md); position: relative; overflow: hidden;">
                <!-- Aksen Garis Atas Teal -->
                <div style="position: absolute; top: 0; left: 0; width: 100%; height: 4px; background: var(--primary);"></div>
                
                <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                    <div>
                        <h3 style="font-size: 0.875rem; color: var(--text-muted); font-weight: 600; margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 1px;">Total Artikel</h3>
                        <p style="font-size: 2.5rem; font-weight: 700; color: var(--text-main); font-family: var(--font-serif);"><%= totalPosts %></p>
                    </div>
                    <div style="background: rgba(23, 86, 106, 0.1); padding: 0.75rem; border-radius: 8px; color: var(--primary);">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                    </div>
                </div>
                <div style="margin-top: 1rem; font-size: 0.875rem; color: var(--primary);">
                    <a href="/admin/posts/new" style="text-decoration: none; color: inherit; font-weight: 500;">+ Tulis artikel baru &rarr;</a>
                </div>
            </div>

            <!-- Card 2 -->
            <div style="background: var(--surface-color); border: 1px solid var(--border-color); border-radius: var(--radius); padding: 1.5rem; box-shadow: var(--shadow-md); position: relative; overflow: hidden;">
                <div style="position: absolute; top: 0; left: 0; width: 100%; height: 4px; background: var(--text-muted);"></div>
                
                <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                    <div>
                        <h3 style="font-size: 0.875rem; color: var(--text-muted); font-weight: 600; margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 1px;">Sistem Database</h3>
                        <p style="font-size: 1.5rem; font-weight: 700; color: var(--text-main); font-family: var(--font-sans); text-transform: capitalize; margin-top: 0.5rem;"><%= dbType %></p>
                    </div>
                    <div style="background: #F1F5F9; padding: 0.75rem; border-radius: 8px; color: var(--text-muted);">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"></path><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path></svg>
                    </div>
                </div>
                <div style="margin-top: 1rem; font-size: 0.875rem; color: var(--text-muted);">
                    Koneksi database aktif.
                </div>
            </div>

        </div>
    </div>
</main>

<%- include('../partials/footer.ejs') %>