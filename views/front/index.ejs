<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - FrizkCMS</title>
    <link rel="stylesheet" href="/public/admin/css/frizk-ui.css">
</head>
<!-- Jika admin sedang login, beri jarak di atas agar topbar tidak menutupi konten -->
<body style="<%= user ? 'padding-top: 40px;' : '' %>">
    
    <!-- Inject Topbar Admin jika sedang login -->
    <% if (user) { %>
        <%- include('../partials/topbar.ejs') %>
    <% } %>

    <main style="max-width: 800px; margin: 4rem auto; padding: 0 1.5rem;">
        <h1 style="font-size: 2.5rem; margin-bottom: 2rem; letter-spacing: -0.025em; border-bottom: 1px solid var(--border-color); padding-bottom: 1rem;">
            Latest Articles
        </h1>

        <div style="display: flex; flex-direction: column; gap: 2.5rem;">
            <% if (posts.length === 0) { %>
                <p style="color: var(--text-muted);">No published articles yet. Check back later!</p>
            <% } else { %>
                <% posts.forEach(post => { %>
                    <article>
                        <h2 style="font-size: 1.5rem; margin-bottom: 0.5rem;">
                            <a href="/post/<%= post.slug %>" style="color: var(--text-main); text-decoration: none;"><%= post.title %></a>
                        </h2>
                        
                        <p style="color: var(--text-main); line-height: 1.6;">
                            <!-- Potong konten jadi ringkasan (150 karakter) -->
                            <%= post.content.substring(0, 150) %><%= post.content.length > 150 ? '...' : '' %>
                        </p>
                        
                        <a href="/post/<%= post.slug %>" style="color: var(--accent-color); font-weight: 500; text-decoration: none; margin-top: 0.5rem; display: inline-block;">
                            Read full article &rarr;
                        </a>
                    </article>
                <% }) %>
            <% } %>
        </div>
    </main>

</body>
</html>